# ---- App runtime (client-safe) ----
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Base URL used in invite emails (e.g. http://localhost:3000 or your deployed URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Server only (NEVER commit real value, NEVER expose to client) ----
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Supabase CLI (set in shell only, do not put real value in any file) ----
# export SUPABASE_ACCESS_TOKEN=... (sbp_...)
